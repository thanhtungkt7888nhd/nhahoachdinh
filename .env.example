# ============================================================
# PHẦN MỀM HOẠCH ĐỊNH – Phạm Thanh Tùng Nhà Hoạch Định
# Copy file này thành .env và điền vào các giá trị
# ============================================================

# DATABASE (PostgreSQL - lấy từ neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# SESSION SECRET (tạo bằng: openssl rand -base64 32)
SESSION_SECRET="your-super-secret-key-change-this"

# URL của trang web (không có dấu / cuối)
NEXT_PUBLIC_APP_URL="https://nhahoachdinh.vn"

# Liên hệ PTT (hiển thị trong footer và CTA)
NEXT_PUBLIC_PTT_PHONE="0900000000"
NEXT_PUBLIC_PTT_EMAIL="phamthanhtung@nhahoachdinh.vn"
