generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Local dev: sqlite | Production: postgresql
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  phone         String?
  plan          String    @default("free")
  freeUsed      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects Project[]
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  status    String   @default("draft")
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputs PlanInput?
  result PlanResult?
}

model PlanInput {
  id        String @id @default(cuid())
  projectId String @unique

  province      String
  area          Float
  tourismType   String
  terrain       String

  budget        Float
  fundingSource String
  targetPayback Int
  targetRevenue Float

  climate        String
  waterSource    String
  existingCrops  String?
  infrastructure String?
  landscape      String?

  targetGuests String
  roomCount    Int
  serviceLevel String
  activities   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PlanResult {
  id        String   @id @default(cuid())
  projectId String   @unique
  data      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
